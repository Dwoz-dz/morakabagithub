# Morakaba Environment Variables
# Copy this file to .env and fill in your values

# Required - Supabase project URL and anon key
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional - useful for environment-specific flags later
EXPO_PUBLIC_APP_ENV=development

# Primary admin email (cannot be demoted or deleted)
EXPO_PUBLIC_PRIMARY_ADMIN_EMAIL=admin@example.com
